[Unit]
Description=Agent Music Telegram Bot + Mini App API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/agent-music-tg/current
# .env lives directly under /opt/agent-music-tg (not inside a release dir) so
# it survives every deploy untouched.
EnvironmentFile=/opt/agent-music-tg/.env
ExecStart=/root/.bun/bin/bun run server/index.ts
Restart=always
RestartSec=5
TimeoutStopSec=10

[Install]
WantedBy=multi-user.target
