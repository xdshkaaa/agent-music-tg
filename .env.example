# Telegram (long-polling — no public webhook route needed)
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs allowed to use the bot at all
ALLOWLIST_CHAT_IDS=
# Comma-separated subset of ALLOWLIST_CHAT_IDS allowed to change provider/backend
ADMIN_CHAT_IDS=

# Public origin the Mini App is served from
PUBLIC_ORIGIN=https://miniapp.xdshka.party

# LLM providers — set whichever the admin will select as active
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
CHEAPVIBECODE_API_KEY=
# opencode hosted gateway (https://opencode.ai/zen) — Anthropic-dialect, Bearer auth
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODEL=claude-sonnet-5
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

# Local genre/personalization layer. It adds no extra LLM or network request;
# set false for an instant rollback to the previous prompt and backend ordering.
RECOMMENDATION_ENRICHMENT_ENABLED=true

# Payments — CryptoBot Crypto Pay
# Master switch: when false, generation is free for everyone (paywall bypassed)
PAYMENTS_ENABLED=true
# API token from @CryptoBot → Crypto Pay → Create App
CRYPTOBOT_TOKEN=
# mainnet (real) or testnet (@CryptoTestnetBot)
CRYPTOBOT_NETWORK=mainnet
# Hourly cap on generations for subscription users (0 = unlimited)
SUBSCRIPTION_HOURLY_LIMIT=25

# Payments — Platega (RUB via СБП)
# Merchant id + secret from Platega dashboard
PLATEGA_MERCHANT_ID=
PLATEGA_SECRET=

# Admin top-up alerts — separate bot token, distinct from TELEGRAM_BOT_TOKEN
ALERT_BOT_TOKEN=
# Comma-separated chat ids to receive alerts (must /start the alert bot first)
ALERT_CHAT_IDS=

# Unused. Bot-side Telegram Premium custom-emoji IDs (inline-button icons and
# <tg-emoji> message headings) are now sourced directly from
# server/bot/emoji-symbols.json — no sticker set or env var needed. Safe to
# remove this line; kept only for backward compatibility with old .env files.
EMOJI_STICKER_SET=

# Server
PORT=8787
DB_PATH=./data/app.sqlite

# Audio download / streaming (yt-dlp + ffmpeg must be installed on the host)
# Scratch dir for downloads sent to chat (files deleted right after upload)
AUDIO_SCRATCH_DIR=./data/audio-scratch

# --- Operator dashboard (dash.xdshka.party) --------------------------------
# Standalone process (server/dashboard-server.ts, bun run dashboard) — reads
# both environments' sqlite files read-only and authenticates operators via
# the Telegram Login Widget (https://core.telegram.org/widgets/login), not
# Mini App initData. See README "Operator dashboard".

# Bot username (no @) for the Telegram Login Widget's data-telegram-login
# attribute. Must be the same bot as TELEGRAM_BOT_TOKEN above.
TELEGRAM_BOT_USERNAME=

# Chat ids allowed to sign in to the dashboard. Defaults to ADMIN_CHAT_IDS if unset.
DASH_ADMIN_CHAT_IDS=

# Random long secret used to sign the dashboard's session cookie. Required.
DASH_SESSION_SECRET=

# Port the dashboard backend listens on (Caddy's dash.xdshka.party block
# reverse-proxies /api/* here — see deploy/dash.caddy).
DASH_PORT=8789

# Read-only paths to each environment's live sqlite file.
DASH_PROD_DB_PATH=/opt/agent-music-tg/current/data/app.sqlite
DASH_DEV_DB_PATH=/opt/agent-music-tg-test/data/app.sqlite

DASH_PUBLIC_ORIGIN=https://dash.xdshka.party
