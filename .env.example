# Telegram (long-polling — no public webhook route needed)
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs allowed to use the bot at all
ALLOWLIST_CHAT_IDS=
# Comma-separated subset of ALLOWLIST_CHAT_IDS allowed to change provider/backend
ADMIN_CHAT_IDS=

# Public origin the Mini App is served from
PUBLIC_ORIGIN=https://miniapp.xdshka.party

# LLM providers — set whichever the admin will select as active
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
# opencode hosted gateway (https://opencode.ai/zen) — Anthropic-dialect, Bearer auth
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODEL=claude-sonnet-5
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

# Payments — CryptoBot Crypto Pay
# Master switch: when false, generation is free for everyone (paywall bypassed)
PAYMENTS_ENABLED=true
# API token from @CryptoBot → Crypto Pay → Create App
CRYPTOBOT_TOKEN=
# mainnet (real) or testnet (@CryptoTestnetBot)
CRYPTOBOT_NETWORK=mainnet

# Optional: Telegram Premium custom-emoji sticker set owned by the bot (name,
# as registered with @BotFather). When set, inline-button labels and message
# headings use the bot's own custom-emoji glyphs (purple). When omitted, plain
# unicode emoji fallbacks are used — no adverse effect.
EMOJI_STICKER_SET=

# Server
PORT=8787
DB_PATH=./data/app.sqlite

# Audio download / streaming (yt-dlp + ffmpeg must be installed on the host)
# Scratch dir for downloads sent to chat (files deleted right after upload)
AUDIO_SCRATCH_DIR=./data/audio-scratch
# On-disk cache for the in-app streaming endpoint (LRU by size + TTL)
STREAM_CACHE_DIR=./data/stream-cache
STREAM_CACHE_MAX_BYTES=209715200
STREAM_CACHE_TTL_SECONDS=86400
