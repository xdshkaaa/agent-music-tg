# Telegram
TELEGRAM_BOT_TOKEN=
# Random path segment used in the webhook URL (https://<domain>/bot/webhook/<secret>)
TELEGRAM_WEBHOOK_SECRET=

# Comma-separated chat IDs allowed to use the bot at all
ALLOWLIST_CHAT_IDS=
# Comma-separated subset of ALLOWLIST_CHAT_IDS allowed to change provider/backend
ADMIN_CHAT_IDS=

# Public origin the Mini App + OAuth callback are served from
PUBLIC_ORIGIN=https://miniapp.xdshka.party

# Spotify (PKCE — no client secret needed)
SPOTIFY_CLIENT_ID=

# LLM providers — set whichever the admin will select as active
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

# Server
PORT=8787
DB_PATH=./data/app.sqlite
